// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
    provider     = "postgresql"
    relationMode = "prisma"
}

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

// Necessary for Next auth
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model User {
    id                  String               @id @default(cuid())
    name                String?
    email               String?              @unique
    emailVerified       DateTime?
    username            String?              @unique
    password            String?
    image               String?
    bio                 String?
    link                String?
    accounts            Account[]
    sessions            Session[]
    tests               Test[]
    scoreShares         ScoreShare[]
    colorConfigurations ColorConfiguration[]
    practiceStats       PracticeStats[]
    transitionStats     TransitionStat[]
    learnProgress       LearnProgress[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model ColorConfiguration {
    id         String   @id @default(cuid())
    userId     String
    name       String   @unique
    background String
    text       String
    primary    String
    secondary  String
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model Test {
    id        String   @id @default(cuid())
    userId    String
    typeId    String
    speed     Float
    accuracy  Float
    consistency Float?
    score     Float
    count     Int      @default(0)
    options   String
    punctuation Boolean @default(false)
    capitals    Boolean @default(false)
    ranked      Boolean @default(true)
    summaryDate DateTime  @db.Date
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    type      TestType @relation(fields: [typeId], references: [id], onDelete: Cascade)
    shares    ScoreShare[]

    @@index([userId])
    @@index([typeId])
}

model ScoreShare {
    id        String    @id @default(cuid())
    slug      String    @unique
    // "score" (a single test) or "progress" (a trend snapshot, no single test).
    kind      String    @default("score")
    testId    String?
    userId    String
    snapshot  Json?
    expiresAt DateTime?
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    test      Test?     @relation(fields: [testId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([testId])
    @@index([userId])
    @@index([expiresAt])
}

model TestType {
    id          String   @id @default(cuid())
    mode        Int
    subMode     Int
    language    String
    competitive Boolean
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    tests Test[]
}

model PracticeStats {
    id        String   @id @default(cuid())
    userId    String
    character String   @db.VarChar(1)
    total     Int
    correct   Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, character])
    @@index([userId])
}

model TransitionStat {
    id        String   @id @default(cuid())
    userId    String
    pair      String   @db.VarChar(2)
    count     Int
    // ponytail: Int, not BigInt — ceiling ~2.1e9 ms (~24 days) of cumulative
    // latency on a single pair; upgrade to BigInt if a heavy user ever nears it.
    totalMs   Int
    errors    Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, pair])
    @@index([userId])
}

model LearnProgress {
    id         String   @id @default(cuid())
    userId     String
    difficulty String
    options    String
    speed      Float
    accuracy   Float
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, difficulty, options])
    @@index([userId])
}
