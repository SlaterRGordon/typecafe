// This is your Prisma schema file,
// Read more in the docs: https://pris.ly/d/prisma-schema

datasource db {
    provider     = "postgresql"
    relationMode = "prisma"
}

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

// Necessary for Next auth
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model User {
    id                  String               @id @default(cuid())
    name                String?
    email               String?              @unique
    emailVerified       DateTime?
    username            String?              @unique
    password            String?
    image               String?
    bio                 String?
    link                String?
    accounts            Account[]
    sessions            Session[]
    tests               Test[]
    scoreShares         ScoreShare[]
    colorConfigurations ColorConfiguration[]
    dailyUserStats      DailyUserStat[]
    practiceStats       PracticeStats[]
    transitionStats     TransitionStat[]
    trainProgress       TrainProgress[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model ColorConfiguration {
    id         String   @id @default(cuid())
    userId     String
    name       String   @unique
    background String
    text       String
    primary    String
    secondary  String
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model Test {
    id        String   @id @default(cuid())
    userId    String
    typeId    String
    speed     Float
    accuracy  Float
    consistency Float?
    // Canonical sortable score: net WPM (backfilled in 20260711140000).
    score     Float
    count     Int      @default(0)
    options   String
    punctuation Boolean @default(false)
    capitals    Boolean @default(false)
    ranked      Boolean @default(true)
    // The keyboard layout the test was typed on (actual id, e.g. "qwertz-de") -
    // honesty metadata for score surfaces; aggregation uses statsPoolFor
    // (docs/features/keyboard-layouts.md decisions 6/10). Legacy rows = qwerty.
    layout    String   @default("qwerty")
    // Full keystroke timeline (locked constraint #2): compact
    // [charCode, correct, dtMs] triples from src/lib/keystrokes.ts. Evidence
    // for replay/re-diagnosis under future heuristics; null on legacy rows.
    timeline    Json?
    summaryDate DateTime  @db.Date
    // The daily-challenge day this test belongs to (null = not a challenge run).
    challengeDate DateTime? @db.Date
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    type      TestType @relation(fields: [typeId], references: [id], onDelete: Cascade)
    shares    ScoreShare[]

    @@index([userId])
    @@index([typeId])
    @@index([challengeDate])
}

model ScoreShare {
    id        String    @id @default(cuid())
    slug      String    @unique
    // "score" (a single test) or "progress" (a trend snapshot, no single test).
    kind      String    @default("score")
    testId    String?
    userId    String?
    snapshot  Json?
    expiresAt DateTime?
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    test      Test?     @relation(fields: [testId], references: [id], onDelete: Cascade)
    user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([testId])
    @@index([userId])
    @@index([expiresAt])
}

// Free-tier durable rate limits for unauthenticated write surfaces. Keys are
// one-way hashes of scope + request identity; raw IP addresses are never stored.
model PublicWriteQuota {
    key       String   @id
    count     Int
    expiresAt DateTime
    updatedAt DateTime @updatedAt

    @@index([expiresAt])
}

model TestType {
    id          String   @id @default(cuid())
    mode        Int
    subMode     Int
    language    String
    competitive Boolean
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    tests Test[]
}

model PracticeStats {
    id        String   @id @default(cuid())
    userId    String
    // Stats pool (statsPoolFor): national layouts share "qwerty", remaps key
    // their own. Legacy rows default into the qwerty pool.
    pool      String   @default("qwerty")
    character String   @db.VarChar(1)
    total     Int
    correct   Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, pool, character])
    @@index([userId])
}

model DailyUserStat {
    id                 String   @id @default(cuid())
    userId             String
    date               DateTime @db.Date
    tests              Int
    bestWpm            Float
    avgWpm             Float
    avgAccuracy        Float
    avgConsistency     Float?
    consistencySamples Int      @default(0)
    // 2 = bestWpm/avgWpm are canonical net WPM. Legacy v1 rows stored raw WPM
    // and cannot always be converted exactly after per-test evidence was folded.
    metricVersion      Int      @default(2)
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, date])
    @@index([userId])
    @@index([date])
}

model TransitionStat {
    id        String   @id @default(cuid())
    userId    String
    // Stats pool (statsPoolFor) - see PracticeStats.pool.
    pool      String   @default("qwerty")
    pair      String   @db.VarChar(2)
    count     Int
    // Int is plenty: rows are rolling windows (ADR-0005) capped at
    // TRANSITION_SAMPLE_CAP samples, so totalMs is bounded, not cumulative.
    totalMs   Int
    errors    Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, pool, pair])
    @@index([userId])
}

model TrainProgress {
    id         String   @id @default(cuid())
    userId     String
    difficulty String
    // Stats pool (statsPoolFor) - see PracticeStats.pool.
    pool       String   @default("qwerty")
    options    String
    speed      Float
    accuracy   Float
    stars      Int      @default(0)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, difficulty, pool, options])
    @@index([userId])
    @@map("LearnProgress")
}
