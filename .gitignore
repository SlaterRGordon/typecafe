/node_modules
/.pnp
.pnp.js

# testing
/coverage
/playwright-report/
/test-results/
/blob-report/

# generated screenshot-tour artifacts
/docs/screenshots/desktop-chromium/*.png
/docs/screenshots/mobile-chromium/*.png

# database
/prisma/db.sqlite
/prisma/db.sqlite-journal

# next.js
/.next/
/.next-check/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
# do not commit any .env files to git, except for the .env.example file. https://create.t3.gg/en/usage/env-variables#using-environment-variables
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# generated prisma client
/src/generated/prisma/

.env*

# extracted word-frequency source (regenerate from data/unigram_freq.zip)
/data/*.csv

# Goodreads quotes dump — build input for gen-quotes.mjs, never committed
/quotes.zip
/quotes.csv
worktrees/

/docs

# local AI agent tooling (skills, configs) — not part of the product
/.claude
/.codex